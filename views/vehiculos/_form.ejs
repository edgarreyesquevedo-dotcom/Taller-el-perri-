<form method="post" action="<%= accion %>" class="card form grid-form" enctype="multipart/form-data">
  <label>
    Placa
    <input type="text" name="placa" value="<%= vehiculo.placa || '' %>" placeholder="ABC-123" required>
  </label>
  <label>
    Marca
    <input type="text" name="marca" value="<%= vehiculo.marca || '' %>" required>
  </label>
  <label>
    Modelo
    <input type="text" name="modelo" value="<%= vehiculo.modelo || '' %>" required>
  </label>
  <label>
    Año
    <input type="number" name="anio" value="<%= vehiculo.anio || '' %>" min="1900" max="<%= new Date().getFullYear() %>" required>
  </label>
  <label>
    Propietario
    <input type="text" name="propietario" value="<%= vehiculo.propietario || '' %>" required>
  </label>
  <label>
    Telefono
    <input type="tel" name="telefono" value="<%= vehiculo.telefono || '' %>" pattern="(?:\D*\d){10}\D*" maxlength="12" placeholder="123-456-7890" data-phone required>
  </label>
  <label class="span-2">
    Imagenes de ingreso del auto
    <input type="file" name="imagenes" accept="image/*" multiple>
    <small>Sube fotos para comprobar como llego el auto al taller.</small>
  </label>
  <% if (vehiculo.imagenes && vehiculo.imagenes.length > 0) { %>
    <div class="vehicle-images span-2">
      <% vehiculo.imagenes.forEach(imagen => { %>
        <a href="<%= imagen %>" target="_blank" rel="noreferrer">
          <img src="<%= imagen %>" alt="Imagen de ingreso del vehiculo">
        </a>
      <% }) %>
    </div>
  <% } %>
  <div class="form-actions">
    <a href="/vehiculos">Cancelar</a>
    <button type="submit"><%= boton %></button>
  </div>
</form>

<script>
  document.querySelectorAll('[data-phone]').forEach(input => {
    input.addEventListener('input', () => {
      const digits = input.value.replace(/\D/g, '').slice(0, 10);
      input.value = [digits.slice(0, 3), digits.slice(3, 6), digits.slice(6, 10)].filter(Boolean).join('-');
    });
  });
</script>
