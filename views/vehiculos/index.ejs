<section class="page-title">
  <div>
    <p class="eyebrow">Clientes y unidades</p>
    <h1>Vehiculos</h1>
  </div>
  <a class="button" href="/vehiculos/nuevo">Nuevo vehiculo</a>
</section>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert error"><%= error %></div>
<% } %>

<section class="card table-card">
  <% if (vehiculos.length === 0) { %>
    <p class="muted">Todavia no hay vehiculos cargados.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Placa</th>
            <th>Vehiculo</th>
            <th>Propietario</th>
            <th>Telefono</th>
            <th>Evidencias</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% vehiculos.forEach(vehiculo => { %>
            <tr>
              <td><strong><%= vehiculo.placa %></strong></td>
              <td><%= vehiculo.marca %> <%= vehiculo.modelo %> (<%= vehiculo.anio %>)</td>
              <td><%= vehiculo.propietario %></td>
              <td><%= vehiculo.telefono %></td>
              <td><%= vehiculo.imagenes && vehiculo.imagenes.length ? `${vehiculo.imagenes.length} imagen(es)` : 'Sin imagenes' %></td>
              <td class="actions">
                <a href="/vehiculos/<%= vehiculo._id %>/editar">Editar</a>
                <form method="post" action="/vehiculos/<%= vehiculo._id %>/eliminar" class="form-eliminar">
                  <button class="danger" type="submit">Eliminar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
