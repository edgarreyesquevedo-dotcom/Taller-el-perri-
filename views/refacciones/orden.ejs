<section class="page-title">
  <div>
    <p class="eyebrow">Compra de inventario</p>
    <h1>Orden de refacciones</h1>
  </div>
  <a class="button" href="/contabilidad">Ver contabilidad</a>
</section>

<section class="stats-grid">
  <article class="metric-card">
    <span>Balance disponible</span>
    <strong>$<%= formatoMoneda(balance) %></strong>
  </article>
</section>

<form method="post" action="/refacciones/orden" class="card form grid-form" id="orden-refacciones">
  <label>
    Fecha de compra
    <input type="date" name="fecha" value="<%= fechaInput(new Date()) %>" required>
  </label>
  <div></div>

  <fieldset class="span-2 parts-field">
    <legend>Refaccion existente</legend>
    <div class="grid-form">
      <label>
        Producto
        <select name="refaccionExistente">
          <option value="">Selecciona una refaccion</option>
          <% refacciones.forEach(refaccion => { %>
            <option value="<%= refaccion._id %>" <%= orden.refaccionExistente === String(refaccion._id) ? 'selected' : '' %>><%= refaccion.nombre %> - <%= refaccion.numeroPieza %></option>
          <% }) %>
        </select>
      </label>
      <label>
        Cantidad a comprar
        <input type="number" name="existenteCantidad" min="0" value="<%= orden.existenteCantidad || 0 %>" data-money-source>
      </label>
      <label>
        Costo unitario de compra
        <input type="number" name="existenteCosto" min="0" step="0.01" value="<%= orden.existenteCosto || 0 %>" data-money-source data-sale-target="existente-venta">
        <small>Precio de venta nuevo: <strong id="existente-venta">$0.00</strong></small>
      </label>
    </div>
  </fieldset>

  <fieldset class="span-2 parts-field">
    <legend>Nueva refaccion</legend>
    <div class="grid-form">
      <label>
        Nombre
        <input type="text" name="nuevoNombre" value="<%= orden.nuevoNombre || '' %>">
      </label>
      <label>
        Numero de pieza
        <input type="text" name="nuevoNumeroPieza" value="<%= orden.nuevoNumeroPieza || '' %>">
      </label>
      <label>
        Categoria
        <select name="nuevoCategoria">
          <option value="">Selecciona una categoria</option>
          <% categorias.forEach(categoria => { %>
            <option value="<%= categoria %>" <%= orden.nuevoCategoria === categoria ? 'selected' : '' %>><%= categoria %></option>
          <% }) %>
        </select>
      </label>
      <label>
        Cantidad a comprar
        <input type="number" name="nuevaCantidad" min="0" value="<%= orden.nuevaCantidad || 0 %>" data-money-source>
      </label>
      <label>
        Costo unitario de compra
        <input type="number" name="nuevaCosto" min="0" step="0.01" value="<%= orden.nuevaCosto || 0 %>" data-money-source data-sale-target="nueva-venta">
        <small>Precio de venta: <strong id="nueva-venta">$0.00</strong></small>
      </label>
    </div>
  </fieldset>

  <div class="price-summary span-2">
    <span>Total de compra</span>
    <strong id="total-compra">$0.00</strong>
    <small>Se descontara del balance del taller al guardar.</small>
  </div>

  <div class="form-actions span-2">
    <a href="/refacciones">Cancelar</a>
    <button type="submit">Registrar orden y descontar balance</button>
  </div>
</form>

<script>
  function moneda(value) {
    return Number(value || 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function actualizarTotalCompra() {
    const existenteCantidad = Number(document.querySelector('[name="existenteCantidad"]').value || 0);
    const existenteCosto = Number(document.querySelector('[name="existenteCosto"]').value || 0);
    const nuevaCantidad = Number(document.querySelector('[name="nuevaCantidad"]').value || 0);
    const nuevaCosto = Number(document.querySelector('[name="nuevaCosto"]').value || 0);
    document.getElementById('total-compra').textContent = `$${moneda((existenteCantidad * existenteCosto) + (nuevaCantidad * nuevaCosto))}`;
    document.getElementById('existente-venta').textContent = `$${moneda(existenteCosto * 1.2)}`;
    document.getElementById('nueva-venta').textContent = `$${moneda(nuevaCosto * 1.2)}`;
  }

  document.querySelectorAll('[data-money-source]').forEach(input => {
    input.addEventListener('input', actualizarTotalCompra);
  });
  actualizarTotalCompra();
</script>
