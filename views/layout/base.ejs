<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= titulo %> | Taller el &quot;perri&quot;</title>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body class="<%= usuario ? 'app-layout' : 'auth-layout' %>">
    <% if (usuario) { %>
      <aside class="sidebar">
        <a class="brand" href="/vehiculos"><span>Taller</span> el &quot;perri&quot;</a>
        <p class="sidebar-label">Operacion</p>
        <nav class="nav">
          <a href="/vehiculos">Vehiculos</a>
          <a href="/servicios">Ordenes</a>
          <a href="/catalogo-servicios">Catalogo servicios</a>
          <a href="/refacciones">Refacciones</a>
          <a href="/empleados">Empleados</a>
          <a href="/contabilidad">Contabilidad</a>
        </nav>
        <div class="sidebar-user">
          <span><%= usuario.email %></span>
          <a href="/logout">Salir</a>
        </div>
      </aside>
    <% } %>

    <main class="content">
      <div class="content-surface">
        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>
        <%- body %>
      </div>
    </main>

    <script>
      document.querySelectorAll('.form-eliminar').forEach(form => {
        form.addEventListener('submit', e => {
          if (!confirm('¿Seguro que deseas eliminar este registro?')) e.preventDefault();
        });
      });
    </script>
  </body>
</html>
