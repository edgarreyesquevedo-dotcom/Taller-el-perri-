<form method="post" action="<%= accion %>" class="card form grid-form" enctype="multipart/form-data">
  <% if (empleado.empleadoId) { %>
    <label>
      ID empleado
      <input type="text" value="<%= empleado.empleadoId %>" readonly>
    </label>
  <% } %>
  <label>
    Puesto
    <select name="puesto" required>
      <option value="">Selecciona un puesto</option>
      <% puestos.forEach(puesto => { %>
        <option value="<%= puesto %>" <%= empleado.puesto === puesto ? 'selected' : '' %>><%= puesto %></option>
      <% }) %>
    </select>
  </label>
  <label>
    Nombre
    <input type="text" name="nombre" value="<%= empleado.nombre || '' %>" required>
  </label>
  <label>
    Apellido paterno
    <input type="text" name="apellidoPaterno" value="<%= empleado.apellidoPaterno || '' %>" required>
  </label>
  <label>
    Apellido materno
    <input type="text" name="apellidoMaterno" value="<%= empleado.apellidoMaterno || '' %>" required>
  </label>
  <label>
    Telefono
    <input type="tel" name="telefono" value="<%= empleado.telefono || '' %>" pattern="(?:\D*\d){10}\D*" maxlength="12" placeholder="123-456-7890" data-phone required>
  </label>
  <label>
    Email
    <input type="email" name="email" value="<%= empleado.email || '' %>" required>
  </label>
  <label class="span-2">
    Dirección
    <input type="text" name="direccion" value="<%= empleado.direccion || '' %>">
  </label>
  <label class="span-2">
    Foto
    <input type="file" name="foto" accept="image/*">
    <small>Sube una foto del empleado. Se guardara en Cloudinary si esta configurado; si no, se guardara localmente.</small>
  </label>
  <% if (empleado.foto) { %>
    <div class="employee-photo span-2">
      <a href="<%= empleado.foto %>" target="_blank" rel="noreferrer">
        <img src="<%= empleado.foto %>" alt="Foto del empleado">
      </a>
    </div>
  <% } %>
  <label>
    Nomina base
    <input type="number" name="nominaBase" value="<%= empleado.nominaBase || '' %>" min="0" step="0.01" required>
  </label>
  <label>
    Fecha de registro
    <input type="date" value="<%= fechaInput(empleado.creadoEn) %>" readonly>
  </label>
  <label>
    RFC
    <input type="text" name="rfc" value="<%= empleado.rfc || '' %>" required>
  </label>
  <label>
    CURP
    <input type="text" name="curp" value="<%= empleado.curp || '' %>" required>
  </label>
  <label>
    Fecha de nacimiento
    <input type="date" name="fechaNacimiento" value="<%= empleado.fechaNacimiento ? fechaInput(empleado.fechaNacimiento) : '' %>" required>
  </label>
  <label class="check-line span-2">
    <input type="checkbox" name="activo" <%= empleado.activo === false ? '' : 'checked' %>>
    Empleado activo
  </label>
  <div class="form-actions span-2">
    <a href="/empleados">Cancelar</a>
    <button type="submit"><%= boton %></button>
  </div>
</form>

<script>
  document.querySelectorAll('[data-phone]').forEach(input => {
    input.addEventListener('input', () => {
      const digits = input.value.replace(/\D/g, '').slice(0, 10);
      input.value = [digits.slice(0, 3), digits.slice(3, 6), digits.slice(6, 10)].filter(Boolean).join('-');
    });
  });
</script>
